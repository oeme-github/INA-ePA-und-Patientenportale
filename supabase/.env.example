# Vorlage für supabase/.env – Datei kopieren und mit echten Werten füllen:
#   cp .env.example .env
# Werte generieren z.B. mit: openssl rand -hex 32

POSTGRES_PASSWORD=
AUTHENTICATOR_PASSWORD=
AUTH_ADMIN_PASSWORD=
JWT_SECRET=
SITE_URL=http://localhost:3000

# Institutionelles SSO (T10, Kandidat Microsoft Entra ID) — optional.
# Nur relevant, wenn eine echte App-Registrierung im Entra-ID-Tenant der
# Organisation existiert (siehe supabase/README.md, Abschnitt SSO). Ohne
# diese Werte bleibt Azure als Login-Provider deaktiviert (Default false).
SSO_AZURE_ENABLED=false
SSO_AZURE_CLIENT_ID=
SSO_AZURE_SECRET=
# Muss in der Entra-ID-App als Redirect-URI hinterlegt sein, z.B.:
# http://localhost:9999/callback (lokal) oder die echte GoTrue-URL (Produktion)
SSO_AZURE_REDIRECT_URI=
# Tenant-spezifischer Endpoint, z.B. https://login.microsoftonline.com/<tenant-id>
SSO_AZURE_TENANT_URL=
